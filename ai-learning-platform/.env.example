# ── Frontend environment variables (Vite) ──────────────────
# Copy to .env for local dev.
# In Vercel: Project Settings → Environment Variables → add each one.
#
# IMPORTANT RULES:
# 1. All vars MUST start with VITE_ to be available in the browser
# 2. VITE_API_URL must NOT include /api at the end
# 3. VITE_SUPABASE_URL must be your real project URL (no placeholder)

# ── Backend API ─────────────────────────────────────────────
# Bare domain only — the app appends /api automatically
VITE_API_URL=https://learn-smart-with-ai-mentor.onrender.com

# ── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://qldctdosdifjdhveuodk.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
