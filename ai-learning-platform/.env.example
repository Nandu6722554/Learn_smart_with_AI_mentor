# ── Frontend environment variables (Vite) ──────────────────
# Copy to .env and fill in your values.
# IMPORTANT: Do NOT include /api at the end of VITE_API_URL
# The frontend automatically appends /api to all requests.

# Backend base URL (bare domain, no trailing slash, no /api)
VITE_API_URL=https://learn-smart-with-ai-mentor.onrender.com

# Supabase (optional — for auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
